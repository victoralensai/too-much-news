# Copy this file to .env and adjust values for your environment.

# Server
PORT=3000
ARCHIVE_FILE_PATH=archive.json

# Archive
ARCHIVE_LIMIT=2000
HISTORY_SYNC_LIMIT=2500
ARCHIVE_SAVE_INTERVAL_MS=300000

# Broadcast pacing (milliseconds)
BROADCAST_DELAY_MIN_MS=300
BROADCAST_DELAY_MAX_MS=1500

# RSS polling (milliseconds)
POLL_INTERVAL_MS=4000
POLL_BATCH_SIZE=1
FEED_TIMEOUT_MS=10000

# Feed failure backoff (milliseconds)
FEED_BACKOFF_MIN_MS=30000
FEED_BACKOFF_MAX_MS=600000
